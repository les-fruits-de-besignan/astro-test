---
import type { Lang } from '../locales';
import { t } from '../locales';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

const SITE_URL = 'https://www.lesfruitsdebésignan.fr';
const ogImage = 'https://res.cloudinary.com/dgkrgabdc/image/upload/v1759491963/IMG_5966_t9wfap.jpg';
const canonicalUrl = `${SITE_URL}${tr.layout.canonicalPath}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Les Fruits de Bésignan — GAEC du vieux château",
  "description": tr.layout.description,
  "url": SITE_URL,
  "email": "gaecduvieuxchateau@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bésignan",
    "addressLocality": "Bésignan",
    "postalCode": "26110",
    "addressRegion": "Drôme",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 44.327,
    "longitude": 5.335
  },
  "sameAs": ["https://www.instagram.com/les_fruits_de_besignan_/"],
};
---
<!doctype html>
<html lang={tr.layout.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{tr.layout.title}</title>
    <meta name="description" content={tr.layout.description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang pour le SEO bilingue -->
    <link rel="alternate" hreflang="fr" href={SITE_URL + "/"} />
    <link rel="alternate" hreflang="en" href={SITE_URL + "/en/"} />
    <link rel="alternate" hreflang="x-default" href={SITE_URL + "/"} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={tr.layout.ogLocale} />
    <meta property="og:site_name" content="Les Fruits de Bésignan" />
    <meta property="og:title" content={tr.layout.title} />
    <meta property="og:description" content={tr.layout.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Vergers de la ferme Les Fruits de Bésignan dans les Baronnies Provençales" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tr.layout.title} />
    <meta name="twitter:description" content={tr.layout.description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" sizes="any" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&family=Dancing+Script:wght@700&display=swap" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
