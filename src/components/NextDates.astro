---
import '../styles/NextDates.css';
---
<section id="Next-dates" class="nextDates" aria-label="Marchés de producteurs">
  <div class="container">
    <h2 class="section-title">Marchés de producteurs</h2>
    <div class="next-dates-grid">
      <div class="next-dates-item">
        <div class="next-dates-icon" aria-hidden="true">📅</div>
        <h3>Bésignan</h3>
        <p class="next-dates-period">Juillet</p>
        <p class="next-dates-desc">Marché de producteurs local</p>
      </div>
      <div class="next-dates-item">
        <div class="next-dates-icon" aria-hidden="true">📅</div>
        <h3>Séderon</h3>
        <p class="next-dates-period">Tout l'été</p>
        <p class="next-dates-desc">Marché de producteurs local</p>
      </div>
      <div class="next-dates-item">
        <div class="next-dates-icon" aria-hidden="true">📅</div>
        <h3>Serres</h3>
        <p class="next-dates-period">21 mars – fin décembre</p>
        <p class="next-dates-desc">Marché de producteurs local</p>
      </div>
    </div>
  </div>
</section>
