---
import '../styles/NextDates.css';
import { farmerMarkets } from '../data/markets';
---
<section id="Next-dates" class="nextDates" aria-label="Marchés de producteurs">
  <div class="container">
    <h2 class="section-title">Marchés de producteurs</h2>
    <div class="next-dates-grid">
      {farmerMarkets.map((market) => (
        <div class="next-dates-item">
          <div class="next-dates-icon" aria-hidden="true">📅</div>
          <h3>{market.location}</h3>
          <p class="next-dates-period">{market.period}</p>
          <p class="next-dates-desc">{market.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
