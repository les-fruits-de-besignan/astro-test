---
import '../styles/NextDates.css';
import type { Lang } from '../locales';
import { t } from '../locales';
import { farmerMarkets } from '../data/markets';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---
<section id="Next-dates" class="nextDates" aria-label="Marchés de producteurs">
  <div class="container">
    <h2 class="section-title">{tr.nextDates.title}</h2>
    <div class="markets-grid">
      {farmerMarkets.map((market) => (
        <div class="market-cell">
          <h3 class="market-loc">{market.location}</h3>
          <span class="market-month">{market.period[lang]}</span>
          <p class="market-desc">{market.description[lang]}</p>
        </div>
      ))}
    </div>
  </div>
</section>
