---
import '../styles/Products.css';
import { productCatalog } from '../data/products';

function formatPrice(amount: number): string {
  return `${amount.toFixed(2).replace('.', ',')} €`;
}
---
<section id="produits" class="section">
  <div class="container">
    <h2 class="section-title">Nos Produits d'Exception</h2>

    {productCatalog.map((category) => (
      <div class="products-category">
        <h3 class="category-title">
          <span aria-hidden="true">{category.emoji}</span> {category.name}
        </h3>
        <div class="products-grid">
          {category.products.map((product) => (
            <div class="product-card">
              <div class="product-image-wrap">
                <img class="product-image" src={product.imageUrl} alt={product.imageAlt} />
              </div>
              <div class="product-body">
                <h4 class="product-title">{product.name}</h4>
                <p class="product-desc" set:html={product.description} />
                <ul class="price-list">
                  {product.seasonItems
                    ? product.seasonItems.map((item) => <li>{item}</li>)
                    : product.prices.map((price) => (
                        <li>
                          {price.prefix}{price.prefix ? ' ' : ''}<span class="price-amount">{formatPrice(price.amount)}</span>{price.prefix ? ' / ' : ' '}{price.unit}
                        </li>
                      ))
                  }
                </ul>
                <a href="#contact" class="product-cta" aria-label={`Commander — ${product.name}`}>Commander</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
