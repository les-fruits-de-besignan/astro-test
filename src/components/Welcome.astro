---
import type { Lang } from '../locales';
import NavBar from './NavBar.astro';
import Hero from './Hero.astro';
import Products from './Products.astro';
import Benefits from './Benefits.astro';
import SalesPoints from './SalesPoints.astro';
import SeasonOffer from './SeasonOffer.astro';
import Contact from './Contact.astro';
import Footer from './Footer.astro';
import NextDates from './NextDates.astro';

import '../styles/global.css';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div id="container">
  <NavBar lang={lang} />
  <main id="main-content">
    <Hero lang={lang} />
    <Products lang={lang} />
    <NextDates lang={lang} />
    <SeasonOffer lang={lang} />
    <Benefits lang={lang} />
    <SalesPoints lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</div>
