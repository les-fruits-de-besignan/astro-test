---
import '../styles/Contact.css';
import type { Lang } from '../locales';
import { t } from '../locales';
import { productCatalog } from '../data/products';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang).contact;

// Single source of truth: the order checkboxes mirror the real product catalog,
// and their `value` (slug) matches the `data-product` on each product CTA.
const orderableProducts = productCatalog.flatMap((category) => category.products);
---
<section id="contact" class="section">
  <div class="container">
    <h2 class="section-title">{tr.sectionTitle}</h2>
    <div class="contact-content">

      <div class="contact-info">
        <h3>{tr.contactTitle}</h3>
        <div class="contact-info-item">
          <span class="contact-info-icon" aria-hidden="true">📧</span>
          <a href="mailto:gaecduvieuxchateau@gmail.com">gaecduvieuxchateau@gmail.com</a>
        </div>
        <div class="contact-info-item">
          <span class="contact-info-icon" aria-hidden="true">📍</span>
          <span>{tr.address}</span>
        </div>
        <div class="social-links">
          <a href="https://www.instagram.com/les_fruits_de_besignan_/" class="social-link" target="_blank" rel="noopener noreferrer" aria-label={tr.instagramAriaLabel}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>
        </div>
      </div>

      <div class="feedback-form">
        <form
          class="contact-form"
          data-netlify="true"
          netlify-honeypot="bot-field"
          name="commande"
          method="POST"
          action="/success"
        >
          <input type="hidden" name="form-name" value="commande" />
          <input type="hidden" name="bot-field" />
          <input type="hidden" name="lang" value={lang} />

          <div class="form-row">
            <div class="form-group">
              <label for="name">{tr.nameLabel}</label>
              <input id="name" type="text" name="name" placeholder={tr.namePlaceholder}
                autocomplete="name" maxlength="80" aria-describedby="name-error" />
              <p class="field-error" id="name-error" hidden>{tr.formErrors.name}</p>
            </div>
            <div class="form-group">
              <label for="tel">{tr.phoneLabel}</label>
              <input id="tel" type="tel" name="tel" placeholder={tr.phonePlaceholder}
                inputmode="tel" autocomplete="tel" maxlength="25" pattern="[0-9+().\s-]{6,25}"
                aria-describedby="tel-error" />
              <p class="field-error" id="tel-error" hidden>{tr.formErrors.phone}</p>
            </div>
          </div>

          <div class="form-group">
            <label for="email">{tr.emailLabel} <span class="required">*</span></label>
            <input id="email" type="email" name="email" placeholder={tr.emailPlaceholder}
              autocomplete="email" maxlength="120" required aria-describedby="email-error" />
            <p class="field-error" id="email-error" hidden>{tr.formErrors.email}</p>
          </div>

          <div class="form-group">
            <label for="delivery">{tr.deliveryLabel} <span class="required">*</span></label>
            <select id="delivery" name="delivery" required aria-describedby="delivery-error">
              <option value="" disabled selected>{tr.deliveryPlaceholder}</option>
              <option value="ferme">{tr.deliveryFarm}</option>
              <option value="livraison">{tr.deliveryHome}</option>
              <option value="marché">{tr.deliveryMarket}</option>
            </select>
            <p class="field-error" id="delivery-error" hidden>{tr.formErrors.delivery}</p>
          </div>

          <fieldset class="form-fieldset">
            <legend>{tr.productsLegend}</legend>
            <div class="products-checkboxes">
              {orderableProducts.map((product) => (
                <label class="checkbox-label">
                  <input type="checkbox" name="products[]" value={product.slug} />
                  {product.name[lang]}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="form-group">
            <label for="message">{tr.messageLabel} <span class="required">*</span></label>
            <textarea id="message" name="message" placeholder={tr.messagePlaceholder}
              maxlength="2000" required aria-describedby="message-error"></textarea>
            <p class="field-error" id="message-error" hidden>{tr.formErrors.message}</p>
          </div>

          <div class="form-group">
            <label class="checkbox-label rgpd-label">
              <input type="checkbox" name="rgpd" value="rgpd" required aria-describedby="rgpd-error" />
              {tr.rgpd} <span class="required">*</span>
            </label>
            <p class="field-error" id="rgpd-error" hidden>{tr.formErrors.consent}</p>
          </div>

          <div class="form-actions">
            <button type="submit" class="submit-button">
              <span class="submit-label">{tr.submit}</span>
              <span class="submit-spinner" aria-hidden="true"></span>
            </button>
            <p class="form-status" role="status" aria-live="polite"></p>
          </div>
        </form>

        <div class="form-success" role="alert" tabindex="-1" hidden>
          <span class="form-success-icon" aria-hidden="true">✓</span>
          <h3>{tr.formStatus.successTitle}</h3>
          <p>{tr.formStatus.successBody}</p>
        </div>
      </div>

      <script
        is:inline
        define:vars={{
          errors: tr.formErrors,
          statusLabels: tr.formStatus,
        }}
      >
        const form = document.querySelector(".contact-form");
        const success = document.querySelector(".form-success");
        if (form && success) {
          // JS available: take over native validation so we can show styled, localized inline errors.
          form.setAttribute("novalidate", "");

          const statusEl = form.querySelector(".form-status");
          const button = form.querySelector(".submit-button");
          let submitted = false;

          const errorMessage = (field) => {
            const v = field.validity;
            if (v.valueMissing) {
              if (field.name === "delivery") return errors.delivery;
              if (field.name === "rgpd") return errors.consent;
              if (field.name === "email") return errors.email;
              if (field.name === "message") return errors.message;
              return errors.name;
            }
            if (v.typeMismatch && field.type === "email") return errors.email;
            if ((v.patternMismatch || v.tooLong) && field.type === "tel") return errors.phone;
            if (v.tooLong && field.name === "name") return errors.name;
            return errors.message;
          };

          const setFieldState = (field) => {
            const errorEl = field.getAttribute("aria-describedby")
              ? document.getElementById(field.getAttribute("aria-describedby"))
              : null;
            if (field.checkValidity()) {
              field.removeAttribute("aria-invalid");
              if (errorEl) errorEl.hidden = true;
              return true;
            }
            field.setAttribute("aria-invalid", "true");
            if (errorEl) {
              errorEl.textContent = errorMessage(field);
              errorEl.hidden = false;
            }
            return false;
          };

          const setStatus = (text, kind) => {
            statusEl.textContent = text || "";
            statusEl.dataset.kind = kind || "";
          };

          // Re-validate a field on blur/change once the user has tried to submit.
          form.querySelectorAll("input, select, textarea").forEach((field) => {
            const revalidate = () => { if (submitted) setFieldState(field); };
            field.addEventListener("blur", revalidate);
            field.addEventListener("change", revalidate);
          });

          form.addEventListener("submit", async (event) => {
            event.preventDefault();
            submitted = true;

            const fields = [...form.querySelectorAll("input, select, textarea")];
            let firstInvalid = null;
            fields.forEach((field) => {
              if (!setFieldState(field) && !firstInvalid) firstInvalid = field;
            });
            if (firstInvalid) {
              setStatus(errors.invalid, "error");
              firstInvalid.focus();
              return;
            }

            button.disabled = true;
            button.classList.add("is-loading");
            setStatus(statusLabels.sending, "sending");

            try {
              const body = new URLSearchParams(new FormData(form)).toString();
              const response = await fetch("/", {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body,
              });
              if (!response.ok) throw new Error("HTTP " + response.status);
              form.hidden = true;
              success.hidden = false;
              success.focus?.();
            } catch (err) {
              setStatus(statusLabels.errorTitle + " — " + statusLabels.errorBody, "error");
            } finally {
              button.disabled = false;
              button.classList.remove("is-loading");
            }
          });

          // Product "Commander" CTAs prefill the matching product checkbox.
          const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const messageField = form.querySelector("#message");
          const contactSection = document.getElementById("contact");
          document.querySelectorAll("a[data-product]").forEach((cta) => {
            cta.addEventListener("click", (event) => {
              const slug = cta.getAttribute("data-product");
              const box = form.querySelector('input[name="products[]"][value="' + slug + '"]');
              if (!box) return; // no match → let the anchor scroll natively
              event.preventDefault();
              box.checked = true;
              const label = box.closest(".checkbox-label");
              if (label) {
                label.classList.remove("just-added");
                void label.offsetWidth; // restart the highlight animation
                label.classList.add("just-added");
              }
              (contactSection || form).scrollIntoView({
                behavior: prefersReduced ? "auto" : "smooth",
                block: "start",
              });
              messageField?.focus({ preventScroll: true });
            });
          });
        }
      </script>
    </div>
  </div>
</section>
