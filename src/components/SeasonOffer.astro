---
import '../styles/SeasonOffer.css';
import type { Lang } from '../locales';
import { t } from '../locales';
import { seasonalItems } from '../data/seasonality';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---
<section id="Seasonnal" class="section bg-light" aria-label="Nos fruits de saison">
  <div class="container">
    <h2 class="section-title">{tr.seasonOffer.title}</h2>
    <figure class="season-banner">
      <img
        src="https://res.cloudinary.com/dgkrgabdc/image/upload/v1759602173/Capture_d_e%CC%81cran_2025-10-04_a%CC%80_20.22.23_xyyquj.png"
        alt="Panier de fruits frais de la ferme du GAEC du vieux château à Bésignan"
      />
    </figure>
    <ol class="season-track">
      {seasonalItems.map((item) => (
        <li class="season-stop">
          <span class="season-dot" aria-hidden="true"></span>
          <span class="season-name">{item.name[lang]}</span>
          <span class="season-month">{item.details[lang]}</span>
        </li>
      ))}
    </ol>
  </div>
</section>
