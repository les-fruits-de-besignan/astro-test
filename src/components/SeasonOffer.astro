---
import '../styles/SeasonOffer.css';
import { seasonalItems } from '../data/seasonality';
---
<section id="Seasonnal" class="section bg-light" aria-label="Nos fruits de saison">
  <div class="container-with-bg">
    <h2 class="section-title">Nos Fruits de Saison</h2>
    <div class="seasonal-fruits-layout">
      <div class="fruits-image">
        <img
          src="https://res.cloudinary.com/dgkrgabdc/image/upload/v1759602173/Capture_d_e%CC%81cran_2025-10-04_a%CC%80_20.22.23_xyyquj.png"
          alt="Panier de fruits frais de la ferme du GAEC du vieux château à Bésignan"
        />
      </div>
      <div class="fruits-details">
        <div class="season-list">
          {seasonalItems.map((item) => (
            <div class="season-item">
              <h3>{item.name}</h3>
              <p>{item.details}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
