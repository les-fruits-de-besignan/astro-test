---
import '../styles/SalesPoints.css';
import type { Lang } from '../locales';
import { t } from '../locales';
import { salesChannels } from '../data/markets';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---
<section id="SalesPoints" class="salesPoints" aria-label="Points de vente">
  <div class="container">
    <h2 class="section-title">{tr.salesPoints.title}</h2>
    <div class="sales-grid">
      {salesChannels.map((channel) => (
        <div class="sales-cell">
          <h3 class="sales-name">{channel.name[lang]}</h3>
          {channel.details.map((detail) => (
            <p class="sales-detail">{detail[lang]}</p>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
